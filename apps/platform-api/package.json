{
  "name": "platform-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "dev": "nest start --watch",
    "build": "nest build",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "node --inspect-brk ./node_modules/vitest/vitest.mjs run --config ./vitest.config.ts --no-file-parallelism",
    "test:e2e": "ENV=test vitest run --config ./test/vitest-e2e.config.ts",
    "test:e2e:file": "ENV=test vitest run --config ./test/vitest-e2e.config.ts",
    "test:e2e:name": "ENV=test vitest run --config ./test/vitest-e2e.config.ts --testNamePattern",
    "lint:test": "eslint \"test/**/*.ts\" --fix",
    "deps:update": "bun update",
    "deps:update:latest": "bun update --latest"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "2.3.3",
    "@aws-sdk/client-s3": "3.1014.0",
    "@aws-sdk/s3-request-presigner": "3.1014.0",
    "@clerk/backend": "3.2.2",
    "@nestjs/common": "11.1.17",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.17",
    "@repo/contracts": "workspace:*",
    "ai": "6.0.134",
    "mongoose": "9.3.1",
    "nestjs-zod": "5.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@swc/core": "1.13.5",
    "@vitest/coverage-v8": "3.2.4",
    "@faker-js/faker": "^10.3.0",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.17",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.5.0",
    "@types/supertest": "7.2.0",
    "eslint": "10.1.0",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "unplugin-swc": "1.5.9",
    "vitest": "3.2.4"
  }
