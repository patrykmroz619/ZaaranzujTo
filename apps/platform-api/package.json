{
  "name": "platform-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "dev": "nest start --watch",
    "build": "nest build",
    "check-types": "tsc --noEmit",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "node --inspect-brk ./node_modules/vitest/vitest.mjs run --config ./vitest.config.ts --no-file-parallelism",
    "test:e2e": "ENV=test vitest run --config ./test/vitest-e2e.config.ts",
    "test:e2e:file": "ENV=test vitest run --config ./test/vitest-e2e.config.ts",
    "test:e2e:name": "ENV=test vitest run --config ./test/vitest-e2e.config.ts --testNamePattern",
    "lint:test": "eslint \"test/**/*.ts\" --fix",
    "deps:update": "bun update",
    "deps:update:latest": "bun update --latest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1053.0",
    "@aws-sdk/s3-request-presigner": "3.1053.0",
    "@clerk/backend": "3.4.13",
    "@nestjs/common": "11.1.23",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.23",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.23",
    "@openrouter/ai-sdk-provider": "2.9.0",
    "@repo/contracts": "workspace:*",
    "ai": "6.0.191",
    "mongoose": "9.6.2",
    "nestjs-zod": "5.4.0",
    "openai": "^6.39.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sharp": "^0.34.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.23",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@swc/core": "1.15.33",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.1",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.4.0",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.7"
  }
}
