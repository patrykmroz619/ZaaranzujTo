## local, staging, production, test
ENV=

## Port number for the server to listen on.
PORT=

## Skip clerk authentication for local environment (for development convenience). Should be set to "true" in local environment and left empty in staging/production.
SKIP_AUTH_FOR_LOCAL_ENV=

AUTHORIZED_PARTIES=
CLERK_SECRET_KEY=

## MongoDB connection settings
DATABASE_URI=
DATABASE_USER=
DATABASE_PASSWORD=

## Cloudflare R2 / S3 Storage Settings
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

## OpenRouter AI Settings
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
VISUALIZATION_IMAGE_MODEL=
