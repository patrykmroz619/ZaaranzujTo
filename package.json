{
  "name": "zaaranzujto",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=platform-api",
    "dev:web": "turbo run dev --filter=platform-web",
    "dev:contracts": "turbo run dev --filter=@repo/contracts",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "deps:update:all": "bun run --filter \"*\" deps:update",
    "deps:update:latest:all": "bun run --filter \"*\" deps:update:latest"
  },
  "devDependencies": {
    "prettier": "3.7.4",
    "turbo": "2.8.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
