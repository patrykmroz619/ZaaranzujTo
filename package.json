{
  "name": "zaaranzujto",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=platform-api",
    "dev:web": "turbo run dev --filter=platform-web",
    "dev:landing": "turbo run dev --filter=landing-page",
    "dev:contracts": "turbo run dev --filter=@repo/contracts",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "deps:update:all": "bun run --filter \"*\" deps:update",
    "deps:update:latest:all": "bun run --filter \"*\" deps:update:latest",
    "deps:update": "bun update",
    "deps:update:latest": "bun update --latest"
  },
  "devDependencies": {
    "prettier": "3.8.2",
    "turbo": "2.9.6",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
